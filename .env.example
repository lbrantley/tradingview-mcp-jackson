# Pushover notifications for the scanner.
# Get keys at https://pushover.net/ — create an Application for the token.
# Set PUSHOVER_ENABLED=1 to actually send; 0 (or unset) silently skips.
PUSHOVER_ENABLED=0
PUSHOVER_TOKEN=
PUSHOVER_USER=

# Auto-push scanner state (observations.jsonl + brief_data.json) at end of
# each pass so cloud-scheduled brief agents see fresh data. Enable on the
# production VM (Azure). Leave off in dev to avoid commit churn on main.
AUTO_PUSH_ENABLED=0

# Anthropic API key for the local brief generator (src/generate_brief.mjs).
# Get one at https://console.anthropic.com — this is separate from any
# Claude Code subscription. Estimated cost: ~$2-3/mo for daily+weekly briefs.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Set to 0 to skip git commit+push of generated briefs (dev). Default on.
BRIEF_GIT_PUSH=1
